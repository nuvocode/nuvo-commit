{
  "name": "nuvo-commit",
  "displayName": "Nuvo Commit",
  "description": "Write commits, not novels. Local-first AI commit message generator.",
  "version": "1.1.2",
  "publisher": "nuvocode",
  "icon": "images/logo.png",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18"
  },
  "categories": [
    "SCM Providers",
    "Machine Learning"
  ],
  "keywords": [
    "git",
    "commit",
    "ai",
    "ollama",
    "openai",
    "anthropic",
    "local-first",
    "multi-provider"
  ],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "nuvoCommit.generate",
        "title": "Nuvo Commit: Generate Commit Message",
        "icon": "$(sparkle)"
      },
      {
        "command": "nuvoCommit.generatePullRequestContent",
        "title": "Nuvo Commit: Generate Pull Request Content",
        "icon": "$(git-pull-request-create)"
      },
      {
        "command": "nuvoCommit.settings",
        "title": "Nuvo Commit: Settings"
      },
      {
        "command": "nuvoCommit.selectModel",
        "title": "Nuvo Commit: Select Model",
        "icon": "$(symbol-boolean)"
      },
      {
        "command": "nuvoCommit.setApiKey",
        "title": "Nuvo Commit: Set API Key"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "nuvoCommit.generate",
          "when": "scmProvider == git",
          "group": "navigation"
        },
        {
          "command": "nuvoCommit.generatePullRequestContent",
          "when": "scmProvider == git",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Nuvo Commit",
      "properties": {
        "nuvoCommit.autoAccept": {
          "type": "boolean",
          "default": true,
          "order": 1,
          "description": "Skip the approval dialog and directly fill the commit message input. Disable to see the approval dialog."
        },
        "nuvoCommit.autoCommit": {
          "type": "boolean",
          "default": false,
          "order": 2,
          "description": "Run `git commit -m <message>` automatically after the user accepts the suggestion."
        },
        "nuvoCommit.includeBody": {
          "type": "boolean",
          "default": false,
          "order": 3,
          "description": "Generate a commit body after the Conventional Commit header. Disabled by default."
        },
        "nuvoCommit.maxDiffChars": {
          "type": "number",
          "default": 12000,
          "minimum": 1000,
          "order": 4,
          "description": "Maximum diff characters sent to the model. Diffs above this are truncated."
        },
        "nuvoCommit.pullRequestBaseBranch": {
          "type": "string",
          "default": "",
          "order": 5,
          "description": "Base branch used when generating pull request content. Leave empty to auto-detect origin/HEAD, then main, then master."
        },
        "nuvoCommit.pullRequestOpenCreateView": {
          "type": "boolean",
          "default": true,
          "order": 6,
          "description": "Open the GitHub Pull Requests create view after accepting generated pull request content."
        },
        "nuvoCommit.pullRequestIncludeCommitList": {
          "type": "boolean",
          "default": true,
          "order": 7,
          "description": "Include branch commit summaries in the prompt when generating pull request content."
        },
        "nuvoCommit.provider": {
          "type": "string",
          "enum": [
            "ollama",
            "openai",
            "anthropic"
          ],
          "enumDescriptions": [
            "Ollama - Local AI provider for running models locally",
            "OpenAI - Cloud API provider (requires API key)",
            "Anthropic - Cloud API provider (requires API key)"
          ],
          "default": "ollama",
          "order": 8,
          "description": "AI provider used to generate commit messages."
        },
        "nuvoCommit.ollama.endpoint": {
          "type": "string",
          "default": "http://localhost:11434/api/generate",
          "order": 9,
          "description": "Ollama API endpoint URL."
        },
        "nuvoCommit.ollama.model": {
          "type": "string",
          "default": "qwen3:4b",
          "order": 10,
          "examples": [
            "qwen3:4b",
            "llama3.2:3b",
            "mistral:7b",
            "codellama:7b",
            "deepseek-coder:6.7b"
          ],
          "description": "Ollama model identifier."
        },
        "nuvoCommit.openai.endpoint": {
          "type": "string",
          "default": "",
          "order": 11,
          "description": "OpenAI API endpoint URL. Leave empty to use the default OpenAI endpoint."
        },
        "nuvoCommit.openai.model": {
          "type": "string",
          "default": "gpt-4o-mini",
          "order": 12,
          "examples": [
            "gpt-4o",
            "gpt-4o-mini",
            "local-model"
          ],
          "description": "OpenAI model identifier."
        },
        "nuvoCommit.anthropic.endpoint": {
          "type": "string",
          "default": "",
          "order": 13,
          "description": "Anthropic API endpoint URL. Leave empty to use the default Anthropic endpoint."
        },
        "nuvoCommit.anthropic.model": {
          "type": "string",
          "default": "claude-3-5-sonnet-20241022",
          "order": 14,
          "examples": [
            "claude-sonnet-4-20250514",
            "claude-3-5-sonnet-20241022"
          ],
          "description": "Anthropic model identifier."
        },
        "nuvoCommit.requestTimeoutMs": {
          "type": "number",
          "default": 30000,
          "minimum": 1000,
          "order": 15,
          "description": "Maximum time in milliseconds to wait for a provider response before aborting the request."
        },
        "nuvoCommit.apiKey": {
          "type": "string",
          "default": "",
          "order": 16,
          "markdownDeprecationMessage": "**Deprecated:** API keys are now stored securely. Run the `Nuvo Commit: Set API Key` command instead. Any value here is migrated automatically and then cleared.",
          "description": "Deprecated. Use the 'Nuvo Commit: Set API Key' command instead."
        },
        "nuvoCommit.endpoint": {
          "type": "string",
          "default": "http://localhost:11434/api/generate",
          "order": 17,
          "markdownDeprecationMessage": "**Deprecated:** Use provider-specific endpoint settings such as `nuvoCommit.ollama.endpoint`, `nuvoCommit.openai.endpoint`, or `nuvoCommit.anthropic.endpoint`.",
          "description": "Deprecated fallback endpoint setting."
        },
        "nuvoCommit.model": {
          "type": "string",
          "default": "qwen3:4b",
          "order": 18,
          "examples": [
            "qwen3:4b",
            "llama3.2:3b",
            "mistral:7b",
            "codellama:7b",
            "deepseek-coder:6.7b",
            "gpt-4o",
            "gpt-4o-mini",
            "claude-sonnet-4-20250514",
            "claude-3-5-sonnet-20241022"
          ],
          "markdownDeprecationMessage": "**Deprecated:** Use provider-specific model settings such as `nuvoCommit.ollama.model`, `nuvoCommit.openai.model`, or `nuvoCommit.anthropic.model`.",
          "description": "Deprecated fallback model setting."
        }
      }
    }
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('out',{recursive:true,force:true})\"",
    "compile": "npm run clean && tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vscode-test",
    "test:unit": "jest",
    "test:coverage": "jest --coverage"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.3.9",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nuvocode/nuvo-commit.git"
  },
  "homepage": "https://github.com/nuvocode/nuvo-commit#readme",
  "bugs": {
    "url": "https://github.com/nuvocode/nuvo-commit/issues"
  },
  "license": "MIT"
}
