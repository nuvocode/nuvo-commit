{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": {
        "preLaunchTask": "${defaultBuildTask}"
      },
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "npm: compile"
    },
    {
      "name": "Extension Tests",
      "type": "extensionHost",
      "request": "launch",
      "name": "vscode-test",
      "args": {
        "preLaunchTask": "${defaultBuildTask}"
      },
      "outFiles": [
        "${workspaceFolder}/out/test/**/*.js"
      ]
    }
  ]
}
